<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.USER.moa</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/bin/python3</string>
		<string>HOME_DIR/tasks/claude-codex-MoA/bin/moa-api</string>
	</array>
	<key>KeepAlive</key>
	<dict>
		<key>SuccessfulExit</key>
		<false/>
	</dict>
	<key>RunAtLoad</key>
	<true/>
	<key>ProcessType</key>
	<string>Background</string>
	<key>StandardErrorPath</key>
	<string>HOME_DIR/.local/share/moa/launchd.err.log</string>
	<key>StandardOutPath</key>
	<string>HOME_DIR/.local/share/moa/launchd.out.log</string>
	<key>Umask</key>
	<integer>63</integer>
</dict>
</plist>
